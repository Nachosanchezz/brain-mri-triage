\usepackage{tcolorbox}
\newcommand{\resaltar}[2][]{
    \vspace{0.4cm}
    \begin{tcolorbox}[{colback=azulUAX!5!white,colframe=azulUAX!75!black,title=#1}]
        #2
    \end{tcolorbox}
}


